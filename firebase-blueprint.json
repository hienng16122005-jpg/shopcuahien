{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user including customers and admins",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["Khách hàng", "Quản trị viên"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "role", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Product in the store",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "brand": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "oldPrice": { "type": "number" },
        "image": { "type": "string" },
        "stock": { "type": "integer" },
        "sold": { "type": "integer" },
        "description": { "type": "string" },
        "details": { "type": "string" },
        "isNew": { "type": "boolean" },
        "discount": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "price", "stock"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerInfo": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "phone": { "type": "string" },
            "email": { "type": "string" },
            "address": { "type": "string" },
            "note": { "type": "string" }
          }
        },
        "items": { "type": "array" },
        "totalPrice": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "status": { "type": "string" },
        "isPaid": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "customerInfo", "items", "totalPrice", "status"]
    },
    "Category": {
      "title": "Category",
      "description": "Product category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" }
      }
    },
    "Magazine": {
      "title": "Magazine Post",
      "description": "Article or blog post",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "content": { "type": "string" },
        "image": { "type": "string" }
      }
    },
    "Config": {
      "title": "Config",
      "description": "Website global configuration",
      "type": "object",
      "properties": {
        "hotline": { "type": "string" },
        "email": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/products/{productId}": { "schema": "Product", "description": "Product collection" },
    "/orders/{orderId}": { "schema": "Order", "description": "Orders collection" },
    "/categories/{categoryId}": { "schema": "Category", "description": "Product categories" },
    "/magazine/{postId}": { "schema": "Magazine", "description": "Magazine posts" },
    "/settings/website": { "schema": "Config", "description": "Global settings" }
  }
}
